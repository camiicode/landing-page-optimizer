---
// index.astro
// LandingLens AI home page
// Import required components

import BaseLayout from '../components/layout/BaseLayout.astro';
import Button from '../components/common/Button.astro';
import Card from '../components/common/Card.astro';
import Input from '../components/common/Input.astro';
import ErrorModal from '../components/common/ErrorModal.astro';

// ── Íconos SVG inline ─────────────────────────────────────────────────────────

// Ícono: enlace / URL
const iconLink = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`;

// Ícono: cerebro / IA
const iconBrain = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>`;

// Ícono: lista de verificación / recomendaciones
const iconList = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`;

// Ícono: pantalla / hero section
const iconHero = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`;

// Ícono: cursor / CTA
const iconCta = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 9 5 12 1.774-5.226L21 14 9 9z"/><path d="m16.071 16.071 4.243 4.243"/></svg>`;

// Ícono: formularios
const iconForm = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`;

// Ícono: SEO / lupa
const iconSeo = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>`;

// Ícono: flecha derecha
const iconArrow = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;

// ── Dashboard Preview Mockup ────────────────────────────────────────────────
const dashboardMockup = `
<div class="w-full max-w-md bg-gradient-to-br from-white/[0.04] to-white/[0.01] border border-white/10 rounded-2xl p-5 sm:p-6 backdrop-blur-sm shadow-2xl shadow-black/30">
  <div class="flex items-center justify-between mb-5">
    <span class="text-xs font-semibold tracking-wider text-gray-400 uppercase">Analysis Results</span>
    <span class="text-[10px] text-gray-500">Example</span>
  </div>

  <div class="flex items-center gap-4 mb-6">
    <div class="w-[68px] h-[68px] relative shrink-0">
      <svg class="w-full h-full -rotate-90" viewBox="0 0 42 42">
        <circle cx="21" cy="21" r="17" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="4"/>
        <circle cx="21" cy="21" r="17" fill="none" stroke="#34d399" stroke-width="4" stroke-linecap="round" stroke-dasharray="106.8" stroke-dashoffset="26.7"/>
      </svg>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-lg font-bold text-white">75</span>
      </div>
    </div>
    <div>
      <div class="text-xs text-gray-400">Overall Score</div>
      <div class="text-lg font-semibold text-transparent bg-linear-to-r from-green-400 to-emerald-300 bg-clip-text">Good</div>
      <div class="flex gap-1.5 mt-1.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-400"></span>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-400/40"></span>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-white/10"></span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-2 mb-4">
    <div class="bg-white/5 rounded-lg p-3 border border-white/5">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-0.5">Hero</div>
      <div class="text-sm font-bold text-white">100</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3 border border-white/5">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-0.5">CTAs</div>
      <div class="text-sm font-bold text-white">100</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3 border border-white/5">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-0.5">Forms</div>
      <div class="text-sm font-bold text-red-400">0</div>
    </div>
    <div class="bg-white/5 rounded-lg p-3 border border-white/5">
      <div class="text-[10px] text-gray-500 uppercase tracking-wider mb-0.5">SEO</div>
      <div class="text-sm font-bold text-white">100</div>
    </div>
  </div>

  <div class="border-t border-white/5 my-3"></div>

  <div class="space-y-2">
    <div class="flex items-center gap-2">
      <span class="text-[10px] text-green-400">✓</span>
      <span class="text-xs text-gray-400">Good value proposition</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-[10px] text-yellow-400">⚠</span>
      <span class="text-xs text-gray-400">No capture form found</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-[10px] text-green-400">✓</span>
      <span class="text-xs text-gray-400">Good on-page SEO</span>
    </div>
  </div>
</div>`;

// ── Step mockups (versión visual de cada paso) ─────────────────────────────────
const stepMockups = [
  // Step 1: Input mockup
  `<div class="w-full bg-white/3 border border-white/8 rounded-xl p-4">
    <div class="flex items-center gap-2 mb-3">
      <div class="flex gap-1.5">
        <span class="w-2 h-2 rounded-full bg-red-500/60"></span>
        <span class="w-2 h-2 rounded-full bg-yellow-500/60"></span>
        <span class="w-2 h-2 rounded-full bg-green-500/60"></span>
      </div>
      <span class="text-[10px] text-gray-500 truncate flex-1">your-domain.com</span>
    </div>
    <div class="flex items-center gap-2 rounded-lg border border-indigo-500/20 bg-indigo-500/5 p-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
      <span class="text-xs text-indigo-300/60 flex-1">mypage.com/landing</span>
      <span class="text-[10px] font-medium text-indigo-300 bg-indigo-500/15 px-2 py-0.5 rounded-md">Analyze</span>
    </div>
  </div>`,
  // Step 2: Loading/analysis mockup
  `<div class="w-full bg-white/3 border border-white/8 rounded-xl p-4">
    <div class="flex items-center gap-3">
      <svg class="w-8 h-8 animate-spin text-indigo-400" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4 31.4" stroke-linecap="round" opacity="0.3"/>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      </svg>
      <div class="flex-1 min-w-0">
        <div class="h-2 bg-white/10 rounded-full w-3/4 mb-1.5 overflow-hidden">
          <div class="h-full bg-indigo-500 rounded-full" style="width:65%"></div>
        </div>
        <div class="h-2 bg-white/10 rounded-full w-1/2 overflow-hidden">
          <div class="h-full bg-indigo-400/60 rounded-full" style="width:40%"></div>
        </div>
      </div>
    </div>
    <div class="flex gap-2 mt-3 text-[10px] text-gray-500">
      <span>Extracting content...</span>
      <span class="text-indigo-400/60">Scoring</span>
      <span class="text-gray-500/50">AI analysis</span>
    </div>
  </div>`,
  // Step 3: Results mockup
  `<div class="w-full bg-white/3 border border-white/8 rounded-xl p-4">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-medium text-green-400">✓ Analysis complete</span>
      <span class="text-[10px] bg-green-500/15 text-green-400 px-1.5 py-0.5 rounded font-medium">75/100</span>
    </div>
    <div class="space-y-2">
      <div class="flex items-center gap-2 text-xs">
        <span class="text-green-400 text-[10px]">✓</span>
        <span class="text-gray-400">Clear value proposition</span>
      </div>
      <div class="flex items-center gap-2 text-xs">
        <span class="text-yellow-400 text-[10px]">!</span>
        <span class="text-gray-400">Add more CTAs</span>
      </div>
      <div class="flex items-center gap-2 text-xs">
        <span class="text-red-400 text-[10px]">✕</span>
        <span class="text-gray-400">No form detected</span>
      </div>
    </div>
    <div class="mt-3 pt-2 border-t border-white/5">
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>
        <span class="text-[10px] text-indigo-400">AI recommendations ready</span>
      </div>
    </div>
  </div>`,
];

// ── Pasos de "Cómo funciona" ──────────────────────────────────────────────────
const steps = [
  {
    number: '01',
    icon: iconLink,
    title: 'Paste your URL',
    description: 'Enter your landing page URL. We support any public domain.',
    mockup: stepMockups[0],
  },
  {
    number: '02',
    icon: iconBrain,
    title: 'AI analysis in seconds',
    description: 'Our engine extracts, evaluates, and scores your page content and structure.',
    mockup: stepMockups[1],
  },
  {
    number: '03',
    icon: iconList,
    title: 'Get recommendations',
    description: 'Receive a detailed report with actionable steps ranked by conversion impact.',
    mockup: stepMockups[2],
  },
];

// ── Sections we analyze ─────────────────────────────────────────────────
const features = [
  {
    icon: iconHero,
    title: 'Hero section',
    description: 'Evaluates whether your value proposition is clear, the message resonates, and the first impression converts.',
  },
  {
    icon: iconCta,
    title: 'Calls to action',
    description: 'Analyzes the text, position, and contrast of each CTA to maximize click-through.',
  },
  {
    icon: iconForm,
    title: 'Forms',
    description: 'Detects friction in your forms: unnecessary fields, usability issues, and more.',
  },
  {
    icon: iconSeo,
    title: 'SEO & accessibility',
    description: 'Reviews metadata, heading hierarchy, color contrast, and screen reader compatibility.',
  },
];
---

<BaseLayout>
  <!-- ══════════════════════════════════════════════════════════════
       HEADER
  ════════════════════════════════════════════════════════════════ -->
  <header class="sticky top-0 z-50 border-b border-white/6 bg-brand/80 backdrop-blur-md">
    <div class="mx-auto! flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="LPO — Home">
        <!-- Icono del logo -->
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-indigo-600 transition-transform duration-200 group-hover:scale-105">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <!-- Nombre del producto -->
        <span class="text-sm font-semibold tracking-tight text-white">
          <span class="text-indigo-400">LPO</span>
        </span>
      </a>

      <!-- Navegación -->
      <nav class="flex items-center gap-1" aria-label="Main navigation">
        <a
          href="https://github.com/camiicode/LandingLensAI"
          class="flex items-center gap-1.5 rounded-md px-3! py-1.5! text-sm text-white/50 transition-colors hover:bg-white/5 hover:text-white/80"
        >
          <!-- Ícono de GitHub -->
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </nav>

    </div>
  </header>

  <main>

    <!-- ══════════════════════════════════════════════════════════════
         HERO SECTION
    ════════════════════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden pb-20! pt-24! sm:pt-32" aria-labelledby="hero-heading">

      <!-- Gradiente de fondo decorativo -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <!-- Luz central -->
        <div
          class="absolute left-1/2 top-0 -translate-x-1/2 opacity-30"
          style="width:900px; height:600px; background: radial-gradient(ellipse at 50% 0%, #4F46E5 0%, transparent 65%); filter: blur(40px);"
        ></div>
        <!-- Cuadrícula sutil -->
        <div
          class="absolute inset-0 opacity-[0.03]"
          style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(to right, #fff 1px, transparent 1px); background-size: 48px 48px;"
        ></div>
      </div>

      <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
        <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-center">

          <!-- ── Columna izquierda: Texto + Formulario ── -->
          <div class="text-center lg:text-left">

            <!-- Badge superior -->
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-indigo-500/20 bg-indigo-500/10 px-3.5 py-1.5 text-xs font-medium text-indigo-300">
              <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-indigo-400"></span>
              AI-powered landing page analysis
            </div>

            <!-- Título principal -->
            <h1
              id="hero-heading"
              class="mb-5 text-4xl font-semibold leading-[1.15] tracking-tight text-white sm:text-5xl lg:text-5xl xl:text-6xl"
            >
              Boost your conversions
              <br />
              <span
                class="bg-linear-to-r from-indigo-400 via-violet-400 to-indigo-300 bg-clip-text text-transparent"
              >
                with AI insights
              </span>
            </h1>

            <!-- Subtitle -->
            <p class="mb-8 max-w-lg text-base leading-relaxed text-white/50 sm:text-lg">
              Paste your landing page URL and get instant AI-powered recommendations to improve your conversion rates.
            </p>

            <!-- ── URL Form ── -->
            <div class="max-w-xl lg:mx-0">

              <!-- Active form -->
              <div id="form-container">
                <div
                  class="relative flex items-center gap-2 rounded-xl border border-white/9 bg-white/3 p-2 shadow-2xl shadow-black/50 backdrop-blur-sm transition-all duration-300 focus-within:border-indigo-500/50 focus-within:bg-white/5 focus-within:shadow-indigo-500/10"
                >
                  <div class="shrink-0 pl-2 text-white/30">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
                      <path d="M2 12h20"/>
                    </svg>
                  </div>

                  <input
                    id="url-input"
                    type="url"
                    placeholder="your-domain.com"
                    autocomplete="url"
                    class="flex-1 bg-transparent text-sm text-white placeholder-white/25 focus:outline-none"
                    aria-label="Landing page URL to analyze"
                  />

                  <button
                    id="analyze-btn"
                    type="button"
                    class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-all duration-200 hover:bg-indigo-500 hover:shadow-indigo-500/30 active:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-transparent"
                    aria-label="Analyze landing page"
                  >
                    Analyze
                    <Fragment set:html={iconArrow} />
                  </button>
                </div>

                <p class="mt-3 text-xs text-white/30">
                  Example: <span class="font-mono text-white/40">mydomain.com/landing</span>
                </p>
              </div>

              <!-- Loading state -->
              <div
                id="loading-container"
                class="hidden flex-col items-center gap-4 py-6"
              >
                <div role="status">
                  <svg aria-hidden="true" class="w-10 h-10 text-white/15 animate-spin! fill-brand-accent" viewBox="0 0 100 101" xmlns="http://www.w3.org/2000/svg">
                    <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
                    <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill"/>
                  </svg>
                  <span class="sr-only">Loading...</span>
                </div>
                <p id="loading-text" class="text-sm text-gray-400">Analyzing...</p>
              </div>

            </div>

          </div>

          <!-- ── Columna derecha: Dashboard Preview ── -->
          <div class="hidden lg:flex justify-center lg:justify-end mt-12 lg:mt-0">
            <div class="relative">
              <!-- Glow detrás del mockup -->
              <div class="absolute -inset-8 opacity-20" style="background: radial-gradient(ellipse at 50% 50%, #4F46E5 0%, transparent 70%); filter: blur(60px);" aria-hidden="true"></div>
              <div class="relative">
                <Fragment set:html={dashboardMockup} />
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         SECTION: HOW IT WORKS
    ════════════════════════════════════════════════════════════════ -->
    <section class="py-20 sm:py-28" aria-labelledby="how-it-works-heading">
