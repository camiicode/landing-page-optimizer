  <!-- ══════════════════════════════════════════════════════════════
       VALIDATION TOAST
  ════════════════════════════════════════════════════════════════ -->
  <div
    id="toast"
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    class="pointer-events-none fixed bottom-6 left-1/2 z-100 -translate-x-1/2 opacity-0"
    style="transition: opacity 0.3s ease;"
  >
    <div
      id="toast-inner"
      class="flex items-center gap-2.5 rounded-lg border px-4 py-3 text-sm font-medium shadow-2xl"
    >
      <span id="toast-icon" class="shrink-0" aria-hidden="true"></span>
      <span id="toast-message"></span>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       CLIENT-SIDE LOGIC (TypeScript)
  ════════════════════════════════════════════════════════════════ -->
  <script>
    // ── Rutas ───────────────────────────────────────────────────
    const basePath = (import.meta as Record<string, any>).env?.BASE_URL?.replace(/\/+$/, '') || '';
    const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? window.location.origin
      : 'https://lpo-backend.onrender.com';

    // ── Referencias al DOM ────────────────────────────────────────
    const urlInput        = document.getElementById('url-input')        as HTMLInputElement;
    const analyzeBtn      = document.getElementById('analyze-btn')      as HTMLButtonElement;
    const formContainer   = document.getElementById('form-container')   as HTMLDivElement;
    const loadingContainer = document.getElementById('loading-container') as HTMLDivElement;
    const loadingText     = document.getElementById('loading-text')     as HTMLParagraphElement;
    const toast           = document.getElementById('toast')            as HTMLDivElement;
    const toastInner      = document.getElementById('toast-inner')      as HTMLDivElement;
    const toastMsg        = document.getElementById('toast-message')    as HTMLSpanElement;
    const toastIcon       = document.getElementById('toast-icon')       as HTMLSpanElement;
    const ctaBtn          = document.querySelector('.cta-scroll')       as HTMLButtonElement;
    const btnOriginalHtml = analyzeBtn.innerHTML;

    // ── Temporizador del toast (para cancelar si se vuelve a mostrar) ─
    let toastTimer: ReturnType<typeof setTimeout> | null = null;

    // ── Validación de URL ─────────────────────────────────────────
    /**
     * Valida que la cadena sea una URL con protocolo http o https.
     * @param url - cadena a validar
     * @returns true si es una URL válida
     */
    function isValidUrl(url: string): boolean {
      if (!url.trim()) return false;
      if (/^https?:\/\//i.test(url)) {
        try {
          const parsed = new URL(url);
          return parsed.protocol === 'http:' || parsed.protocol === 'https:';
        } catch {
          return false;
        }
      }
      return /^[^\s]+\.[^\s]+$/.test(url);
    }

    // ── Mostrar toast ─────────────────────────────────────────────
    /**
     * Muestra un mensaje temporal en la parte inferior de la pantalla.
     * @param message  - texto del mensaje
     * @param type     - 'error' | 'success'
     */
    function showToast(message: string, type: 'error' | 'success' = 'error'): void {
      // Limpiar temporizador anterior
      if (toastTimer) clearTimeout(toastTimer);

      // Configurar estilos según tipo
      if (type === 'error') {
        toastInner.className = 'flex items-center gap-2.5 rounded-lg border border-red-500/30 bg-red-950/80 px-4 py-3 text-sm font-medium shadow-2xl text-red-300 backdrop-blur-md';
        toastIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;
      } else {
        toastInner.className = 'flex items-center gap-2.5 rounded-lg border border-emerald-500/30 bg-emerald-950/80 px-4 py-3 text-sm font-medium shadow-2xl text-emerald-300 backdrop-blur-md';
        toastIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
      }

      toastMsg.textContent = message;

      // Animar entrada
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(-50%) translateY(10px)';
      toast.style.transition = 'opacity 0.25s ease, transform 0.25s ease';

      // Forzar reflow para que la transición funcione
      void toast.offsetHeight;

      toast.style.opacity = '1';
      toast.style.transform = 'translateX(-50%) translateY(0)';

      // Ocultar automáticamente tras 3.5 segundos
      toastTimer = setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(-50%) translateY(6px)';
      }, 3500);
    }

    // ── Lógica principal de análisis ──────────────────────────────
    /**
     * Valida la URL y, si es correcta, dispara el análisis vía API.
     */
    async function handleAnalyze(): Promise<void> {
      const url = urlInput.value.trim();

      if (!url) {
        showToast('Enter a URL to analyze.', 'error');
        urlInput.focus();
        return;
      }

      if (!isValidUrl(url)) {
        showToast('Invalid URL format. Check the address and try again', 'error');
        urlInput.focus();
        return;
      }

      // ── Loading state ─────────────────────────────────────
      formContainer.classList.add('hidden');
      loadingContainer.classList.remove('hidden');
      loadingContainer.classList.add('flex');
      loadingText.textContent = `Analyzing ${url}\u2026`;
      showToast(`Analyzing ${url}\u2026`, 'success');

      try {
        const response = await fetch(`${API_BASE}/api/extract`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url }),
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Failed to analyze the page');
        }

        sessionStorage.setItem('extractionResult', JSON.stringify({ data: result.data, score: result.score }));
        window.location.href = `${basePath}/analyze?url=${encodeURIComponent(url)}`;
      } catch (error) {
        const msg = error instanceof Error ? error.message : '';
        formContainer.classList.remove('hidden');
        loadingContainer.classList.add('hidden');
        loadingContainer.classList.remove('flex');
        if (/timeout/i.test(msg)) {
          (window as any).showErrorModal?.();
        } else if (/ERR_NAME_NOT_RESOLVED|ENOTFOUND/i.test(msg)) {
          showToast('The domain was not found. Check that the URL is correct and publicly accessible.', 'error');
        } else if (/ERR_CONNECTION_REFUSED|ECONNREFUSED/i.test(msg)) {
          showToast('The connection was refused. The server may be blocking automated analysis tools.', 'error');
        } else {
          showToast('Could not analyze the URL. Check the address and try again.', 'error');
        }
      }
    }

    // ── Eventos ───────────────────────────────────────────────────

    // Click en botón "Analizar"
    analyzeBtn.addEventListener('click', handleAnalyze);

    // Enter dentro del input
    urlInput.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter') handleAnalyze();
    });

    // Scroll al hero al hacer click en el CTA inferior
    ctaBtn?.addEventListener('click', () => {
      urlInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      // Pequeño delay para dar tiempo al scroll antes de hacer focus
      setTimeout(() => urlInput.focus(), 400);
    });
  </script>

</BaseLayout>