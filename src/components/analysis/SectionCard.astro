---
export interface Props {
  title: string;
  score: number;
  message?: string;
  strengths?: string[];
  issues?: string[];
  recommendations?: string[];
}

const { title, score, message, strengths = [], issues = [], recommendations = [] } = Astro.props;
const scoreColor = score >= 70 ? 'text-green-400' : score >= 50 ? 'text-yellow-400' : 'text-red-400';
---

<div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-white/20 transition">
  <div class="flex items-center justify-between mb-3">
    <h3 class="font-medium text-white">{title}</h3>
    <span class={"text-sm font-bold " + scoreColor}>{score}/100</span>
  </div>

  {message && (
    <p class="text-sm text-gray-300 mb-3">{message}</p>
  )}

  {strengths.length > 0 && (
    <div class="mb-2 space-y-1">
      {strengths.slice(0, 2).map(s => (
        <div class="text-sm text-green-400/90"><span class="text-green-400">&#10003;</span> {s}</div>
      ))}
    </div>
  )}

  {issues.length > 0 && (
    <div class="space-y-1">
      {issues.slice(0, 2).map(i => (
        <div class="text-sm text-red-400/90"><span class="text-red-400">&#9888;</span> {i}</div>
      ))}
    </div>
  )}

  {recommendations.length > 0 && (
    <div class="mt-3 pt-3 border-t border-white/10">
      {recommendations.slice(0, 2).map(r => (
        <div class="text-sm text-indigo-300/90"><span class="text-indigo-300">&#128161;</span> {r}</div>
      ))}
    </div>
  )}
</div>
