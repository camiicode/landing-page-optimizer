<button
  id="export-pdf-btn"
  class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-sm text-gray-300 transition hover:bg-white/10 hover:text-white disabled:opacity-50 disabled:cursor-not-allowed"
  aria-label="Download PDF"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
    <polyline points="14 2 14 8 20 8"/>
    <line x1="16" y1="13" x2="8" y2="13"/>
    <line x1="16" y1="17" x2="8" y2="17"/>
    <polyline points="10 9 9 9 8 9"/>
  </svg>
  <span id="export-pdf-label">Download PDF</span>
</button>
<div id="export-pdf-status" class="text-xs text-gray-500 mt-1 text-right"></div>

<script>
  const btn = document.getElementById('export-pdf-btn') as HTMLButtonElement;
  const label = document.getElementById('export-pdf-label') as HTMLSpanElement;
  const status = document.getElementById('export-pdf-status') as HTMLDivElement;

  function setStatus(msg: string, isError = false) {
    status.textContent = msg;
    status.className = `text-xs mt-1 text-right ${isError ? 'text-red-400' : 'text-gray-500'}`;
  }

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    label.textContent = 'Generating PDF...';
    setStatus('');

    try {
      const stored = sessionStorage.getItem('extractionResult');
      if (!stored) throw new Error('No analysis data found');

      const { data, score, analysis } = JSON.parse(stored);

      const { buildExportHtml, generatePdf } = await import('../../utils/pdf');

      const html = buildExportHtml(data, score, analysis);
      const filename = `lpo-report-${Date.now()}.pdf`;

      await generatePdf(html, filename);
      setStatus('PDF downloaded successfully');
    } catch (err: any) {
      const msg = err?.message || 'Unknown error';
      setStatus(msg.includes('timed out') ? 'Timed out. Try again or use a simpler page.' : `Error: ${msg}`, true);
      console.error('PDF export failed:', err);
    } finally {
      label.textContent = 'Download PDF';
      btn.disabled = false;
    }
  });
</script>
