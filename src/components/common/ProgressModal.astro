<!-- Progress Modal — barra de progreso animada con etapas, cancelar y checkmark -->

<div
  id="progress-modal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-label="Analysis in progress"
>
  <div class="relative mx-4 w-full max-w-sm rounded-2xl border border-white/8 bg-[#0d0d0d] p-8 shadow-2xl shadow-black/60">
    <!-- Spinner / Checkmark -->
    <div id="progress-icon" class="mb-6 flex justify-center">
      <!-- Spinner (default) -->
      <div id="progress-spinner" class="flex items-center justify-center">
        <svg aria-hidden="true" class="h-12 w-12 animate-spin! text-indigo-400" viewBox="0 0 100 101" xmlns="http://www.w3.org/2000/svg">
          <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
          <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill"/>
        </svg>
      </div>
      <!-- Checkmark (hidden until complete) -->
      <div id="progress-checkmark" class="hidden">
        <svg class="h-14 w-14" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
    </div>

    <!-- Barra de progreso -->
    <div class="mb-4">
      <div class="h-2 w-full overflow-hidden rounded-full bg-white/8">
        <div
          id="progress-bar"
          class="h-full w-0 rounded-full bg-indigo-500 transition-all duration-500 ease-out"
          style="width: 0%"
        ></div>
      </div>
    </div>

    <!-- Porcentaje y texto -->
    <div class="mb-2 text-center">
      <span id="progress-pct" class="text-sm font-bold text-white">0%</span>
    </div>
    <p id="progress-text" class="text-center text-sm text-gray-400">Starting...</p>

    <!-- Botón Cancel -->
    <div class="mt-6 text-center">
      <button
        id="progress-cancel-btn"
        class="rounded-md px-4 py-1.5 text-xs text-gray-500 transition hover:bg-white/5 hover:text-gray-300"
      >
        Cancel
      </button>
    </div>
  </div>
</div>

<style>
  #progress-bar {
    background-image: linear-gradient(90deg, #6366f1, #818cf8, #6366f1);
    background-size: 200% 100%;
  }
  #progress-bar.glowing {
    box-shadow: 0 0 10px rgba(99, 102, 241, 0.5);
  }
  #progress-bar.complete {
    background-image: linear-gradient(90deg, #34d399, #10b981);
    box-shadow: 0 0 14px rgba(52, 211, 153, 0.5);
  }
  #progress-bar.error {
    background-image: linear-gradient(90deg, #ef4444, #f87171);
    box-shadow: 0 0 14px rgba(239, 68, 68, 0.5);
  }
  #progress-checkmark svg {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: drawCheck 0.6s ease-out forwards;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }
</style>

<script>
  let cancelCallback: (() => void) | null = null;

  function show(abortController: AbortController | null) {
    const modal = document.getElementById('progress-modal')!;
    const bar = document.getElementById('progress-bar')!;
    const pct = document.getElementById('progress-pct')!;
    const text = document.getElementById('progress-text')!;
    const spinner = document.getElementById('progress-spinner')!;
    const checkmark = document.getElementById('progress-checkmark')!;

    // Reset
    bar.className = 'h-full w-0 rounded-full bg-indigo-500 transition-all duration-500 ease-out';
    bar.style.width = '0%';
    pct.textContent = '0%';
    text.textContent = 'Starting...';
    spinner.classList.remove('hidden');
    checkmark.classList.add('hidden');

    modal.classList.remove('pointer-events-none', 'opacity-0');
    modal.classList.add('opacity-100');

    cancelCallback = abortController ? () => abortController.abort() : null;
  }

  function update(pctValue: number, stageText: string) {
    const bar = document.getElementById('progress-bar')!;
    const pct = document.getElementById('progress-pct')!;
    const text = document.getElementById('progress-text')!;

    const clamped = Math.min(100, Math.max(0, pctValue));
    bar.style.width = `${clamped}%`;
    bar.classList.add('glowing');
    pct.textContent = `${Math.round(clamped)}%`;
    text.textContent = stageText;
  }

  function complete() {
    const bar = document.getElementById('progress-bar')!;
    const pct = document.getElementById('progress-pct')!;
    const text = document.getElementById('progress-text')!;
    const spinner = document.getElementById('progress-spinner')!;
    const checkmark = document.getElementById('progress-checkmark')!;
    const iconContainer = document.getElementById('progress-icon')!;

    // Bar to 100%
    bar.style.width = '100%';
    bar.classList.remove('glowing');
    bar.classList.add('complete');
    pct.textContent = '100%';

    // Hide spinner, show checkmark with animation
    spinner.classList.add('hidden');
    checkmark.classList.remove('hidden');
    checkmark.innerHTML = checkmark.innerHTML; // re-trigger animation

    text.textContent = '✅ Analysis complete! Taking you to your results...';

    // Remove cancel button
    cancelCallback = null;
  }

  function fail(errorMsg: string) {
    const bar = document.getElementById('progress-bar')!;
    const pct = document.getElementById('progress-pct')!;
    const text = document.getElementById('progress-text')!;
    const spinner = document.getElementById('progress-spinner')!;

    bar.classList.remove('glowing');
    bar.classList.add('error');
    pct.textContent = 'Error';
    text.textContent = errorMsg || 'Analysis failed';
    spinner.innerHTML = `
      <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>`;

    cancelCallback = null;
  }

  function hide() {
    const modal = document.getElementById('progress-modal')!;
    modal.classList.add('pointer-events-none');
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');
    cancelCallback = null;
  }

  // Expose API
  (window as any).progressModal = { show, update, complete, fail, hide };

  // Cancel button
  document.getElementById('progress-cancel-btn')!.addEventListener('click', () => {
    if (cancelCallback) {
      cancelCallback();
      const modal = document.getElementById('progress-modal')!;
      modal.classList.add('pointer-events-none');
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      cancelCallback = null;
    }
  });
</script>
